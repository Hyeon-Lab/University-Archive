package Chapter12_Thread_Synchronized_Wait;

import java.awt.*;
import javax.swing.*;

class TimerRunnable implements Runnable {
	private JLabel timerLabel;// Åļïŋ―Ėļïŋ― ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ÂĩĮīïŋ― ïŋ―ïŋ―ïŋ―Ėšïŋ―
	
	public TimerRunnable(JLabel timerLabel) {
		this.timerLabel = timerLabel; 
	}
	
	@Override
	public void run() {
		int n=0; // Åļïŋ―Ėļïŋ― ÄŦïŋ―ïŋ―ÆŪ ïŋ―ïŋ―
		while(true) { 
			timerLabel.setText(Integer.toString(n)); // ïŋ―ïŋ―ïŋ―Ėšïŋ― ÄŦïŋ―ïŋ―ÆŪ ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―
			n++; 
			try {
				Thread.sleep(1000); // 1ïŋ―Ęĩïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―Üīïŋ―.
			}
			catch(InterruptedException e) {
				return; 
			}
		}
	}
}

public class RunnableTimerEx extends JFrame {
	public RunnableTimerEx() {
		setTitle("Runnableïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― Åļïŋ―Ėļïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―");
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		Container c = getContentPane();
		c.setLayout(new FlowLayout());

		JLabel timerLabel = new JLabel();
		timerLabel.setFont(new Font("Gothic", Font.ITALIC, 80));
		c.add(timerLabel); 
		
		TimerRunnable runnable = new TimerRunnable(timerLabel);
		Thread th = new Thread(runnable);
		
		setSize(250,150);
		setVisible(true);
		
		th.start(); // Åļïŋ―Ėļïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Ï°ïŋ― ïŋ―Ņīïŋ―.
	}
	public static void main(String[] args) {
		new ThreadTimerEx();
	}
}