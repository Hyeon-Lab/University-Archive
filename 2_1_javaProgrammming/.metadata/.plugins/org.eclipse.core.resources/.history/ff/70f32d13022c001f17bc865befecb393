package Chapter12_Thread_Synchronized_Wait;

import java.awt.*;
import java.awt.event.*;
import javax.swing.*;
import java.util.Random;

public class VibratingFrame extends JFrame implements Runnable {
	private Thread th; // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฯด๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
	public VibratingFrame() {
		setTitle("๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฯด๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ");
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		setSize(200,200);
		setLocation(300,300); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝฤก๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝลฉ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ (300,300)๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
		setVisible(true);
		
		getContentPane().addMouseListener(new MouseAdapter() {
			public void mousePressed(MouseEvent e) {
				if(!th.isAlive()) return; // ๏ฟฝฬน๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝๅฐก ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ฿ดูธ๏ฟฝ ๏ฟฝืณ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
				th.interrupt(); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝๅฟก๏ฟฝ๏ฟฝ InterruptedException ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
			}
		});
		
		th = new Thread(this); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฯด๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝรผ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
		th.start(); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
	}

	@Override
	public void run() { // 20ms๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝฤก๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฯฐ๏ฟฝ ๏ฟฝฬต๏ฟฝ
		Random r = new Random();
		while(true) {
			try {
				Thread.sleep(20); // 20ms ๏ฟฝ๏ฟฝ๏ฟฝฺฑ๏ฟฝ
			}
			catch(InterruptedException e){
				return; // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฯธ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
			}
			int x = getX() + r.nextInt()%5; // ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝฤก x
			int y = getY() + r.nextInt()%5; // ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝฤก y 
			setLocation(x, y); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝฤก ๏ฟฝฬต๏ฟฝ
		}
	}

	public static void main(String [] args) {
		new VibratingFrame();
	}
} 