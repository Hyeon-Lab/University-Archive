				else 
					b.setText("Action");
				
				// AnonymousClassListenerïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― JFrameïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ČĢïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―
				setTitle(b.getText());			
			}
		});
		
		setSize(300,300);
		setVisible(true);
	}
	
	public static void main(String [] args) {
		new AnonymousClassListener();
	}
}