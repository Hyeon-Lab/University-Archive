public class FlyingTextEx extends JFrame {
	private JLabel la = new JLabel("HELLO"); // Å° ïŋ―Ô·Âŋïŋ― ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―Ėšïŋ― ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ÆŪ 
	
	public FlyingTextEx() {
		super("ïŋ―ïŋ―,ïŋ―ïŋ―,ïŋ―ïŋ―,ïŋ―ïŋ― Å°ïŋ―ïŋ― ïŋ―Ėŋïŋ―ïŋ―Ïŋïŋ― ïŋ―Ø―ïŋ―ÆŪ ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Ėąïŋ―");
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

		Container c = getContentPane();
		c.setLayout(null); // ïŋ―ïŋ―ïŋ―ïŋ―ÆŪïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ÄĄïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―
		c.addKeyListener(new MyKeyListener()); // ïŋ―ïŋ―ïŋ―ïŋ―ÆŪïŋ―Ōŋïŋ― Å° ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―Þąïŋ―
		la.setLocation(50,50); // ïŋ―ïŋ―ïŋ―Ėšïŋ―ïŋ―ïŋ― ïŋ―Ęąïŋ― ïŋ―ïŋ―ÄĄïŋ―ïŋ― (50,50)
		la.setSize(100,20);
		c.add(la);
		setSize(200,200);
		setVisible(true);
		
		c.setFocusable(true); // ïŋ―ïŋ―ïŋ―ïŋ―ÆŪïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―Äŋïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ― ïŋ―Öĩïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―
		c.requestFocus(); // ïŋ―ïŋ―ïŋ―ïŋ―ÆŪïŋ―ïŋ―ïŋ―ïŋ― Å° ïŋ―Ô·ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ― ïŋ―Öĩïŋ―ïŋ―ïŋ― ïŋ―ïŋ―Äŋïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―	
	}
	
	class MyKeyListener extends KeyAdapter { // Key ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ïŋ―ïŋ―
		public void keyPressed(KeyEvent e) {
			int keyCode = e.getKeyCode(); // ïŋ―Ô·Âĩïŋ― Å°ïŋ―ïŋ― Å°ïŋ―ÚĩåļĶ ïŋ―ËūÆģïŋ―ïŋ―ïŋ―.
			switch(keyCode) { // Å° ïŋ―ÚĩåŋĄ ïŋ―ïŋ―ïŋ―ïŋ― ïŋ―ïŋ―,ïŋ―ïŋ―,ïŋ―ïŋ―,ïŋ―ïŋ― Å° ïŋ―Įšïŋ―, ïŋ―ïŋ―ïŋ―Ėšïŋ―ïŋ―ïŋ― ïŋ―ïŋ―ÄĄ ïŋ―Ėĩïŋ―
				case KeyEvent.VK_UP:  //UP Å°
					la.setLocation(la.getX(), la.getY() - 10); break;
				case KeyEvent.VK_DOWN: //DOWN Å° 
					la.setLocation(la.getX(), la.getY() + 10); break;
				case KeyEvent.VK_LEFT: //LEFT Å°
					la.setLocation(la.getX() - 10, la.getY()); break;
				case KeyEvent.VK_RIGHT: //RIGHT Å°
					la.setLocation(la.getX() + 10, la.getY()); break;				
			}
		}
	}
	
	public static void main(String [] args) {
		new FlyingTextEx();
	}
}