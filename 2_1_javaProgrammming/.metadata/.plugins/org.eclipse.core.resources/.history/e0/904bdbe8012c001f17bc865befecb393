package Chapter12_Thread_Synchronized_Wait;

import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

class MyLabel extends JLabel {
	private int barSize = 0; // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ลฉ๏ฟฝ๏ฟฝ
	private int maxBarSize;
	
	public MyLabel(int maxBarSize) { 
		this.maxBarSize = maxBarSize;
	}
	
	public void paintComponent(Graphics g) {
		super.paintComponent(g); 
		g.setColor(Color.MAGENTA);
		int width = (int) (((double)(getWidth()))/maxBarSize*barSize);
		if(width==0) return; // ลฉ๏ฟฝโฐก 0๏ฟฝฬฑ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝูธ๏ฟฝ ๏ฟฝืธ๏ฟฝ ๏ฟฝสฟ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
		g.fillRect(0, 0, width, this.getHeight());
	}
	
	synchronized void fill() {
		if(barSize == maxBarSize) {
			try {
				wait(); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ลฉ๏ฟฝโฐก ๏ฟฝึด๏ฟฝ๏ฟฝฬธ๏ฟฝ, ComsumerThread๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ลฉ๏ฟฝโฐก ๏ฟฝูพ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ
			} catch (InterruptedException e) { return; }
		}
		barSize++;
		repaint(); // ๏ฟฝ๏ฟฝ ๏ฟฝูฝ๏ฟฝ ๏ฟฝืธ๏ฟฝ๏ฟฝ๏ฟฝ
		notify(); // ๏ฟฝ๏ฟฝูธ๏ฟฝ๏ฟฝ๏ฟฝ ConsumerThread ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
	}
	synchronized void consume() {
		if(barSize == 0) {
			try {
				wait(); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ลฉ๏ฟฝโฐก 0๏ฟฝฬธ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ลฉ๏ฟฝโฐก 0๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ฤฟ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ
			} catch (InterruptedException e) { return; }
		}
		barSize--;
		repaint(); // ๏ฟฝ๏ฟฝ ๏ฟฝูฝ๏ฟฝ ๏ฟฝืธ๏ฟฝ๏ฟฝ๏ฟฝ
		notify(); // ๏ฟฝ๏ฟฝูธ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝฬบ๏ฟฝฦฎ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
	}	
}

class ConsumerThread extends Thread {
	private MyLabel bar;
	
	public ConsumerThread(MyLabel bar) { this.bar = bar; }
	
	@Override
	public void run() {
		while(true) {
			try {
				sleep(100);
				bar.consume(); // 0.1๏ฟฝสธ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝูธ๏ฟฝ 1๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝฮด๏ฟฝ.
			} catch (InterruptedException e) { return; }
		}
	}
}

public class TabAndThreadEx  extends JFrame {
	private MyLabel bar = new MyLabel(100); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝึด๏ฟฝ ลฉ๏ฟฝโธฆ 100๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
	
	public TabAndThreadEx(String title) {
		super(title);
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		Container c = getContentPane();
		c.setLayout(null);
		bar.setBackground(Color.ORANGE);
		bar.setOpaque(true);
		bar.setLocation(20,  50);
		bar.setSize(300, 20); // 300x20 ลฉ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ
		c.add(bar);
		
		// ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฦฎ๏ฟฝาฟ๏ฟฝ ลฐ ๏ฟฝฬบ๏ฟฝฦฎ ๏ฟฝฺต้ทฏ ๏ฟฝ๏ฟฝ๏ฟฝ
		c.addKeyListener(new KeyAdapter() {
			public void keyPressed(KeyEvent e) {
				bar.fill(); // ลฐ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝูฐ๏ฟฝ 1๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝัด๏ฟฝ.
			}
		});
		setSize(350,200);
		setVisible(true);
		
		c.setFocusable(true); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฦฎ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝฤฟ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ ๏ฟฝึต๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
		c.requestFocus(); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝฦฎ๏ฟฝาฟ๏ฟฝ๏ฟฝ๏ฟฝ ลฐ ๏ฟฝิท๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝฮฟ๏ฟฝ
		ConsumerThread th = new ConsumerThread(bar); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
		th.start(); // ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ
	}

	public static void main(String[] args) {
		new TabAndThreadEx("๏ฟฝฦน๏ฟฝลฐ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ๏ฟฝ๏ฟฝ ๏ฟฝ๏ฟฝ รค๏ฟฝ๏ฟฝ๏ฟฝ");
	}
}